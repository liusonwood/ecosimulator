{
  "name": "ecosim",
  "version": "3.3.1",
  "description": "EcoSim - Ecological Succession Simulator",
  "main": "electron-main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac"
  },
  "author": "liusonwood&yanyi-lin",
  "license": "GNU AGPL-3.0",
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.ecosim.simulator",
    "productName": "EcoSim",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "android-chrome-512x512.png"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "android-chrome-512x512.png"
    },
    "files": [
      "index.html",
      "main.js",
      "electron-main.js",
      "preload.js",
      "style.css",
      "lib/**/*",
      "favicon.ico",
      "apple-touch-icon.png",
      "android-chrome-192x192.png",
      "android-chrome-512x512.png",
      "site.webmanifest"
    ]
  }
}
